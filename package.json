{
  "name": "thunderbird-agent",
  "version": "0.6.0",
  "description": "Thunderbird extension, CLI, and vendor-neutral skill pack for AI agents to automate mail, contacts, filters, and calendars",
  "author": "Tomasz Kasperczyk",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/buddhism5080/thunderbird-agent"
  },
  "homepage": "https://github.com/buddhism5080/thunderbird-agent",
  "bugs": {
    "url": "https://github.com/buddhism5080/thunderbird-agent/issues"
  },
  "keywords": [
    "thunderbird",
    "email",
    "ai",
    "agents",
    "claude",
    "codex",
    "openclaw",
    "cli",
    "skills"
  ],
  "bin": {
    "thunderbird-agent": "./packages/cli/thunderbird-agent.cjs"
  },
  "files": [
    "packages/",
    "shared/",
    "skills/",
    "docs/agents/",
    "dist/thunderbird-agent.xpi",
    "extension/",
    "scripts/",
    "AGENTS.md",
    "CLAUDE.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test",
    "build:catalog": "node ./scripts/export-tool-catalog.cjs",
    "catalog:export": "npm run build:catalog",
    "check:versions": "node ./scripts/check-versions.cjs",
    "build:xpi": "node ./scripts/build-xpi.cjs",
    "build": "npm run check:versions && npm run build:catalog && npm run build:xpi",
    "doctor": "node ./packages/cli/thunderbird-agent.cjs doctor",
    "pack:check": "npm pack --dry-run --json",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
